# Database configuration
# SQLite (default, no setup required)
DATABASE_URL=sqlite:///./coachspark.db
# PostgreSQL example: DATABASE_URL=postgresql://user:password@localhost:5432/coachspark

# OpenRouter API key (required)
# Get your API key from https://openrouter.ai/
OPENAI_API_KEY=sk-or-v1-your-api-key-here

# LLM model to use via OpenRouter
# Options: google/gemini-2.5-flash, anthropic/claude-3.5-sonnet, openai/gpt-4o, etc.
OPENAI_MODEL=google/gemini-2.5-flash

# OpenRouter API base URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Application environment: development | production
APP_ENV=development

# Allowed CORS origins (JSON array of URLs)
# Development: ["http://localhost:3000","http://localhost:5173"]
# Production: replace with your actual frontend domain
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
